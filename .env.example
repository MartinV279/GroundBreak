# Example environment configuration for the Ollama desktop chat app
# Copy this file to ".env" and adjust values as needed.

# API key for Ollama web_search / web_fetch (if required).
OLLAMA_API_KEY=your_key_here

# Override the default model (optional).
MODEL=qwen3.5:4b

# Enable verbose debug logging in the terminal (0 or 1).
DEBUG=0
